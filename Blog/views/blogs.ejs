<%- include("partials/header.ejs") %>
<% blogs.forEach(blog => { %>

<div class="blog-post" id="blog-<%= blog.id %>">

    <h1><%= blog.title %></h1>
    <p><%= blog.text %></p>
    <button
        class="delete-btn"
        data-id="<%= blog.id %>">
        Delete
    </button>

</div>

<% }) %>

<script src="/js/script.js"></script>
<%- include("partials/footer.ejs") %>